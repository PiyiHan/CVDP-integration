FROM ace-rtl-base@sha256:6460b01f13fd1d7f3a334ec08273fd04ff3fee78c522174e91175b2ef70c4357
#To avoid duplicate load
# FROM mage-base

WORKDIR /app

# Create /code directory and set permissions
RUN mkdir -p /code && chmod 777 /code

# Copy requirements file
COPY requirements.txt ./

RUN pip install -r requirements.txt
# Copy MAGE source code
COPY src /app/src
# Copy agent code
COPY mage_agent.py /app/agent.py

#RUN pip list | grep llama

# Set entrypoint
ENTRYPOINT ["python3.12", "/app/agent.py"]

